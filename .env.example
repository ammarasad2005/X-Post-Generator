# OPENROUTER_API_KEY: Required. The app uses OpenRouter exclusively as its LLM
# provider (Gemini has been removed due to free-tier rate limits and
# availability issues). Get a free key at https://openrouter.ai/keys.
#
# Leave EMPTY if not yet configured — the app will fail fast with a clear
# UPSTREAM_UNAVAILABLE error on first request, rather than silently using a
# placeholder value.
OPENROUTER_API_KEY=

# APP_URL: The URL where this app is hosted. Used as the OpenRouter
# HTTP-Referer header. Set to your production URL when deployed.
APP_URL=http://localhost:3000

# OPENROUTER_PRIMARY_MODEL: Optional. Override the primary free model used
# for generation. Default: nvidia/nemotron-3-ultra-550b-a55b:free (most
# reliable as of 2026-07-07 — other free models are frequently rate-limited).
# Browse all free models at https://openrouter.ai/models?q=free
# Note: google/gemini-2.5-flash:free was removed from the free tier — use
# "google/gemini-2.5-flash" (no :free suffix) with a paid OpenRouter account.
OPENROUTER_PRIMARY_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# LOG_LEVEL: Optional. One of debug | info | warn | error. Default: info.
LOG_LEVEL=info
