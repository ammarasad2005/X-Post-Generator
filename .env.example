# GEMINI_API_KEY: Required for Gemini AI API calls.
# Get one at https://aistudio.google.com/apikey
# Leave EMPTY if not yet configured — the app will fail fast with a clear
# UPSTREAM_UNAVAILABLE error on first request, rather than silently using
# a placeholder value.
GEMINI_API_KEY=

# APP_URL: The URL where this app is hosted. Used as the OpenRouter
# HTTP-Referer header and for self-referential links. Set to your production
# URL when deployed.
APP_URL=http://localhost:3000

# OPENROUTER_API_KEY: Optional fallback used when Gemini quota is exhausted
# or the Gemini API is unreachable. Get one at https://openrouter.ai/keys.
# Leave EMPTY to disable the fallback path.
OPENROUTER_API_KEY=

# LOG_LEVEL: Optional. One of debug | info | warn | error. Default: info.
LOG_LEVEL=info
